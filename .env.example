# Groq API Configuration (https://console.groq.com)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=gsk_your_api_key_here

# Groq Model Configuration
GROQ_GENERATION_MODEL=llama-3.3-70b-versatile

# Gemini API Configuration (https://aistudio.google.com/apikey)
VITE_GEMINI_API_KEY=your_gemini_key_here

# YouTube Data API v3 Configuration (https://console.cloud.google.com)
VITE_YOUTUBE_API_KEY=your_youtube_key_here
