rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'preferences', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 5 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.preferences is map &&
             data.preferences.keys().hasAll(['theme', 'dyslexiaFont', 'fontSize', 'focusMode', 'highContrast', 'speechRate']) &&
             data.preferences.theme in ['light', 'dark', 'high-contrast'] &&
             data.preferences.dyslexiaFont is bool &&
             data.preferences.fontSize is number &&
             data.preferences.focusMode is bool &&
             data.preferences.highContrast is bool &&
             data.preferences.speechRate is number &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['title', 'videoUrl', 'authorId', 'createdAt']) &&
             data.keys().size() >= 4 &&
             data.title is string && data.title.size() <= 256 &&
             data.videoUrl is string && data.videoUrl.size() <= 2048 &&
             data.authorId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidTranscriptSegment(data) {
      return data.keys().hasAll(['startTime', 'endTime', 'text', 'signAnimation', 'glosses']) &&
             data.startTime is number && data.startTime >= 0 &&
             data.endTime is number && data.endTime >= data.startTime &&
             data.text is string && data.text.size() <= 1000 &&
             data.signAnimation is string &&
             data.glosses is list && data.glosses.size() <= 50;
    }

    // --- Core Rules ---

    // Test Connection
    match /test/connection {
      allow read: if true;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['preferences', 'updatedAt', 'email']);
    }

    // Lessons Collection
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
                      isValidLesson(incoming()) &&
                      isValidId(lessonId) &&
                      incoming().createdAt == request.time;
      allow update: if isSignedIn() && 
                      existing().authorId == request.auth.uid &&
                      isValidLesson(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['title', 'simplifiedContent']);
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;

      // Subcollection: Transcripts
      match /transcripts/{segmentId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && 
                       get(/databases/$(database)/documents/lessons/$(lessonId)).data.authorId == request.auth.uid &&
                       isValidTranscriptSegment(incoming());
      }
    }
  }
}
